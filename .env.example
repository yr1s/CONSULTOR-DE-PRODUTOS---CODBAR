# Copie este arquivo para .env e preencha com suas credenciais reais
# cp .env.example .env

# === Conexão com o banco (escolha uma das opções) ===

# Opção 1: string completa (recomendado)
DATABASE_URL=postgresql://USUARIO:SENHA@IP_DO_BANCO:5432/NOME_DO_BANCO

# Opção 2: variáveis separadas (usado se DATABASE_URL estiver vazio)
# DB_HOST=127.0.0.1
# DB_PORT=5432
# DB_NAME=postgres
# DB_USER=postgres
# DB_PASSWORD=

# === Configurações do Flask ===
HOST=0.0.0.0
PORT=3000

# === Opcionais ===
API_KEY=                    # Chave de autenticação para /api/busca (deixe vazio para desabilitar)
ENABLE_CORS=0               # 1 para habilitar CORS (só necessário se o HTML não for servido pelo Flask)
USE_UNACCENT=0              # 1 para usar extensão unaccent do PostgreSQL na busca
STATEMENT_TIMEOUT_MS=30000  # Timeout de queries em ms

# === Limites de resultados ===
CAND_LIMIT=100              # Candidatos na busca textual
RESULT_LIMIT=100            # Resultados retornados pela API

# === Busca fuzzy (pg_trgm) ===
USE_FUZZY=1
FUZZY_MIN_SIM=0.32
FUZZY_CAND_LIMIT=120
FUZZY_TRIGGER_RESULTS=0
